rules_version = '2';

// Правила безопасности Firestore для проекта bus-seat-planner.
// Вставьте этот текст в консоли Firebase:
//   Databases & Storage -> Firestore -> вкладка "Rules" -> заменить содержимое -> Publish
//
// Логика:
// - читать коллекцию profiles может кто угодно (без входа) — чтобы
//   index.html могла показывать схему всем посетителям сайта.
// - создавать/изменять/удалять профили может только вошедший
//   пользователь (email/password), т.е. администратор из admin.html.
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{profileId} {
      allow get, list: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
